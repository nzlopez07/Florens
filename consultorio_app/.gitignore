# Estrategia: ignorar todo y permitir solo lo necesario para esta app.
*

# Permitir este archivo
!.gitignore

# Permitir carpetas de la app
!app/
!app/**
!config/
!config/**
!tools/
!tools/**

# Data local: no se versiona (opcional: dejar solo .gitkeep)
data/
!data/.gitkeep

# Permitir archivos raíz necesarios para ejecución/distribución
!run.py
!requirements.txt
!README.md
!LEEME.txt
!version.txt
!Florens.spec

# Ruido explícito (aunque esté dentro de carpetas permitidas)
**/__pycache__/
**/*.py[cod]
**/*.pyo
**/*.pyd
**/*.so
**/*.log

# Entornos virtuales y secretos
venv/
.venv/
ENV/
env/
.env
.env.local

# IDE / SO
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Carpetas de salida / pruebas / documentación no necesarias para deploy runtime
build/
dist/
docs/
tests/
logs/

# Mantener fuera artefactos ad-hoc
nuevosRecs.txt

